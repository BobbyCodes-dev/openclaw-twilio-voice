# OpenClaw + Twilio Voice - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# ============================================================================
# TWILIO CONFIGURATION
# ============================================================================
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio phone number (format: +15551234567)
TWILIO_PHONE_NUMBER=+15551234567

# ============================================================================
# OLLAMA CONFIGURATION
# ============================================================================
# URL where Ollama is running (default: localhost)
OLLAMA_URL=http://localhost:11434

# Model to use for voice responses (recommend: llama3.2 or phi3)
OLLAMA_MODEL=llama3.2

# ============================================================================
# OPENCLAW CONFIGURATION (Optional)
# ============================================================================
# URL of your OpenClaw instance (for notifications)
OPENCLAW_URL=http://localhost:8080

# Secret key for webhook authentication
OPENCLAW_SECRET=your_openclaw_secret_here

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Public URL where this webhook server is accessible
# Used for outbound calls and status callbacks
PUBLIC_URL=https://your-domain-or-ngrok-url.com

# Port to run the server on (default: 8000)
PORT=8000

# ============================================================================
# OPTIONAL FEATURES
# ============================================================================
# Enable Twilio signature validation (recommended for production)
VALIDATE_TWILIO_SIGNATURE=true

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable call recording
ENABLE_RECORDING=false

# Maximum call duration in minutes
MAX_CALL_DURATION=10
